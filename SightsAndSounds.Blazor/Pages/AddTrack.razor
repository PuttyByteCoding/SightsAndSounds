@using SightsAndSounds.Shared.Models;
@using SightsAndSounds.Blazor.Services;
@inject ITrackService TrackService;




@code {
    private Track track = new Track();
    private List<Track>? allTracks = new List<Track>();
    protected override async Task OnInitializedAsync()
    {
        allTracks = await TrackService.GetTracksAsync();
    }
    private async Task HandleValidSubmit()
    {
        await TrackService.CreateTrackAsync(track);
        track = new Track(); // Reset the form
        allTracks = await TrackService.GetTracksAsync(); // Refresh the list
    }
}
