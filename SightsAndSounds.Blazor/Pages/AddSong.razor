@using SightsAndSounds.Shared.Models;
@using SightsAndSounds.Blazor.Services;
@inject ISongService SongService;

<h2>AddSong</h2>

@if (allSongs is null)
{
    <p>Loading…</p>
}
else
{

    <EditForm Model="@song" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
    
    
         <!-- Name -->
        <div class="form-group">
            <label for="Name">Song Name</label>
            <InputText id="Name" class="form-control" @bind-Value="song.Name" />
            <ValidationMessage For="@(() => song.Name)" />
        </div>
        
        
        @* Alternate Names - tag pills *@
        <div class="form-group">
            <label>Alternate Names</label>
            <div class="form-control p-2" style="min-height: 3rem;">
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    @if (song.AlternateNames is { Count: > 0 })
                    {
                        @foreach (var name in song.AlternateNames)
                        {
                            <span class="badge text-bg-secondary">
                                @name
                                <button type="button"
                                        class="btn btn-sm btn-close btn-close-white ms-1"
                                        aria-label="Remove"
                                        title="Remove"
                                        @onclick="() => RemoveAltName(name)">
                                </button>
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">No alternate names</span>
                    }

                    <input class="border-0 flex-grow-1"
                           style="min-width: 10ch; outline: none;"
                           placeholder="Type name, press Ctrl+Enter to add"
                           value="@newAltName"
                           @oninput="e => newAltName = e.Value?.ToString() ?? string.Empty"
                           @onkeydown="OnAltNameKeyDown" />
                </div>
            </div>
        </div>
        


        <!-- Album -->
        <div class="form-group">
            <label for="Album">Album</label>
            <InputText id="Album" class="form-control" @bind-Value="song.Album" />
            <ValidationMessage For="@(() => song.Album)" />
        </div>

        <!-- Live Debut -->
        <div class="form-group">
            <label for="LiveDebut">Live Debut</label>
            <InputDate id="LiveDebut" class="form-control" @bind-Value="song.LiveDebut" />
            <ValidationMessage For="@(() => song.LiveDebut)" />
        </div>


        <!-- Notes -->
        <div class="form-group">
            <label for="Notes">Notes</label>
            <InputText id="Notes" class="form-control" @bind-Value="song.Notes" />
        </div>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-primary"
                @onclick:preventDefault="true"
                @onkeydown="OnSubmitKeyDown">
            Add Song
        </button>


    </EditForm>
}

@code {
    private Song song = new Song();
    private List<Song>? allSongs = new List<Song>();
    private string newAltName = String.Empty;
    
    protected override async Task OnInitializedAsync()
    {
        allSongs = await SongService.GetSongsAsync();
    }
    
    
    private void OnAltNameKeyDown(KeyboardEventArgs e)
    {
        // Block plain Enter from submitting: convert it to a no-op by handling it here
        if (!e.CtrlKey && e.Key == "Enter")
        {
            return;
        }
        
        if (e.CtrlKey && e.Key == "Enter")
        {
            AddAltName();
        }
    }
    
    
    // Submit only when the submit button has focus and Space is pressed.
    // Enter does nothing. Ctrl+Enter adds an alternate name instead of submitting.
    private async Task OnSubmitKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey && e.Key == "Enter")
        {
            AddAltName();
            return;
        }

        if (!e.CtrlKey && e.Key == " " )
        {
            await HandleValidSubmit();
            return;
        }

        // Ignore Enter
        if (!e.CtrlKey && e.Key == "Enter")
        {
            return;
        }
    }
    
    private void AddAltName()
    {
        var value = newAltName?.Trim();
        if (string.IsNullOrEmpty(value))
            return;

        song.AlternateNames ??= new();
        if (!song.AlternateNames.Contains(value, StringComparer.OrdinalIgnoreCase))
        {
            song.AlternateNames.Add(value);
        }
        newAltName = string.Empty;
    }

    private void RemoveAltName(string name)
    {
        if (song.AlternateNames is null) return;
        var index = song.AlternateNames.FindIndex(n => string.Equals(n, name, StringComparison.OrdinalIgnoreCase));
        if (index >= 0)
        {
            song.AlternateNames.RemoveAt(index);
        }
    }
    
    
    
    private async Task HandleValidSubmit()
    {
        await SongService.CreateSongAsync(song);
        song = new Song(); // Reset the form
        newAltName = String.Empty;
        allSongs = await SongService.GetSongsAsync(); // Refresh the list
    }
}
