# Sights and Sounds — environment configuration
# Copy this file to .env and customize. The same vars drive:
#   1. docker-compose.yml (the postgres container's POSTGRES_* env)
#   2. The API / ImportTool / ThumbnailTool (start.sh sources .env so the
#      dotnet processes inherit these — Program.cs reads them to build the
#      connection string).
# Never commit a real password.

POSTGRES_DB=videoorganizer
POSTGRES_USER=postgresuser
POSTGRES_PASSWORD=changeme

# Optional postgres overrides — defaults shown.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Bootstrap-only video storage paths. Used to seed a Default VideoSet on
# first startup; runtime VideoSets in the DB are authoritative thereafter.
# Double underscores (__) bind to nested ASP.NET Core config keys.
# VideoStorage__Root=C:/path/to/your/videos
# VideoStorage__ThumbnailsDirectory=C:/path/to/your/videos/_Thumbnails
