# Sights and Sounds — environment configuration
# Copy this file to .env and customize. The same vars drive:
#   1. docker-compose.yml (the postgres container's POSTGRES_* env)
#   2. The API / ImportTool / ThumbnailTool (start.sh sources .env so the
#      dotnet processes inherit these — Program.cs reads them to build the
#      connection string).
# Never commit a real password.

POSTGRES_DB=videoorganizer
POSTGRES_USER=postgresuser
POSTGRES_PASSWORD=changeme

# Optional postgres overrides — defaults shown.
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Bootstrap-only video storage paths. Used to seed a Default VideoSet on
# first startup; runtime VideoSets in the DB are authoritative thereafter.
# Double underscores (__) bind to nested ASP.NET Core config keys.
# VideoStorage__Root=C:/path/to/your/videos
# VideoStorage__ThumbnailsDirectory=C:/path/to/your/videos/_Thumbnails

# --- Keycloak (#124, auth) ---------------------------------------------------
# Bootstrap admin for the Keycloak admin console at http://localhost:8080.
# This is the master-realm superuser, NOT an app user (the app users — viewer /
# owner — live in the imported `sightsandsounds` realm). Change before exposing.
# Keycloak reuses the POSTGRES_* connection above with its own `keycloak`
# database (created by the keycloak-db-init compose service).
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme

# --- LAN deployment: auth + IP allowlist + HTTPS (#221, #222) -----------------
# Everything below is OFF by default (the tracked app ships no-auth over HTTP).
# Uncomment + adjust to turn on Keycloak auth, the IP allowlist, and forced
# HTTPS for a LAN deployment. Full walkthrough: docs/lan-https-deployment.md.
#
# IMPORTANT: KC_HOSTNAME and Auth__Authority must name the SAME host (and scheme)
# the browser uses to reach Keycloak — otherwise tokens carry an issuer the API
# rejects and only the host itself can log in (#221).
#
# Replace 192.168.4.38 with this host's LAN IP, and the AllowedCidrs with the
# devices allowed in (the host's own IP included so it isn't limited to loopback).

# Turn Keycloak auth on. start.sh brings up the keycloak container when this is true.
# Auth__Enabled=true
# Auth__Authority=https://192.168.4.38:8443/realms/sightsandsounds
# Auth__RequireHttpsMetadata=true

# Pin Keycloak's issuer to the same host (see docker-compose.yml). With the TLS
# overlay use the https://…:8443 URL; for plain HTTP bring-up use http://192.168.4.38:8080.
# KC_HOSTNAME=https://192.168.4.38:8443
# KC_DISCOVERY_URL=https://192.168.4.38:8443/realms/sightsandsounds/.well-known/openid-configuration

# Restrict access to specific devices. Loopback is always allowed; .38 is the
# host itself (so its own desktop reaches the app over the LAN IP, not just loopback).
# Network__RestrictByIp=true
# Network__AllowedCidrs__0=192.168.4.120/32
# Network__AllowedCidrs__1=192.168.4.24/32
# Network__AllowedCidrs__2=192.168.4.38/32

# Force HTTPS. Generate the cert first: ./gen-cert.sh 192.168.4.38 <pfx-password>
# Network__ForceHttps=true
# ASPNETCORE_URLS=https://0.0.0.0:5098
# Kestrel__Certificates__Default__Path=certs/sights.pfx
# Kestrel__Certificates__Default__Password=changeit
