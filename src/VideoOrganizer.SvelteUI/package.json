{
  "name": "videoorganizer-svelteui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "svelte-kit sync || echo 'svelte-kit sync skipped'",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "daisyui": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "cookie": "^0.7.2"
  }
}
