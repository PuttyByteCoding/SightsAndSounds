## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Local script state (PIDs + logs from start.sh / start-fresh.sh / stop.sh)
.run/

# Claude Code (CLI) — project-local config, hooks, commands, agents, skills.
# CLAUDE.md and Notes-for-AI.md ARE checked in; everything below is local-only.
.claude/
.claude.json
CLAUDE.local.md

# AI-generated planning / audit / scratch docs (Claude tends to create these
# when iterating on a task). Patterns are conservative — bare PLAN.md /
# TODO.md stay tracked if you want them committed.
*.plan.md
PLAN_*.md
AUDIT_*.md
AUDIT.md
SCRATCH.md
SCRATCH_*.md
.scratch/

# Build results
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Rr]elease/
[Dd]ebug/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
out/
artifacts/

# Visual Studio files
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.sln.iml

# Generated files
Generated_Code/
*.generated.cs

# NuGet packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# Azure build output
csx/
*.build.csdef

# Microsoft Azure Emulator
ecf/
rcf/

# Windows image file caches
Thumbs.db
ehthumbs.db

# User-specific files
*.rsuser
*.userprefs

# Auto-generated test results
TestResult*/
[Tt]est[Rr]esult*/
*.VisualState.xml
*.nunit.xml
*.trx

# Coverage reports
*.coverage
*.coveragexml
.coverage/
coverage/

# Logs
*.log

# DotCover
.idea/.idea.DotSettings.user

# Temporary and backup files
*.bak
*.tmp
*.temp
*.swp
*.swo

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider plugin cache
.idea/.idea.*

# Entity Framework Migrations
Migrations/obj/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# SvelteKit / Node frontend artifacts
node_modules/
npm-debug.log
yarn-error.log
.svelte-kit/
src/VideoOrganizer.SvelteUI/build/

# Publish output
publish/
*.publish.xml
*.pubxml
*.pubxml.user
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt

# Local secrets
# secrets.json
appsettings.Development.json

# VS Code launch/settings
.vscode/

# macOS files
.DS_Store

# Windows crash dumps
*.stackdump

# Environment files
.env
.env.*
!.env.example

# Docker — keep the root docker-compose.yml tracked (postgres setup) but
# ignore local override files.
docker-compose.override.yml
docker-compose.override.yaml

# Local tools and cache
.toolstarget
.tools/
.cache/

# Generated thumbnails
thumbnails/
ffmpeg
ffprobe

ffmpeg.exe
ffprobe.exe

# Personal tag seed (used only on first-run boot when the tag_groups table
# is empty). Keep your seed local; share an example via tags.seed.example.json
# if you want one tracked.
tags.seed.json

# Other 
appsettings.Development.json